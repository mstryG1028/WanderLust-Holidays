<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<style>

body{
    background:#f5f7fb;
    overflow-x:hidden;
}

/* Sidebar */

.sidebar{
    min-height:100vh;
    background:linear-gradient(180deg,#021b4f,#041132);
}

.logo{
    color:white;
    font-size:1.6rem;
    font-weight:700;
}

.sidebar a{
    display:flex;
    align-items:center;
    gap:12px;
    color:white;
    text-decoration:none;
    padding:14px;
    border-radius:12px;
    margin-bottom:10px;
    transition:.3s;
}

.sidebar a:hover,
.sidebar a.active{
    background:#2563eb;
}

.sidebar i{
    width:20px;
}

/* Cards */

.stat-card{
    border:none;
    border-radius:18px;
    transition:.3s;
}

.stat-card:hover{
    transform:translateY(-4px);
}

.icon-box{
    width:60px;
    height:60px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    color:white;
    font-size:22px;
}

.bg-blue{
    background:#2563eb;
}

.bg-green{
    background:#16a34a;
}

.bg-purple{
    background:#7c3aed;
}

.bg-orange{
    background:#f97316;
}

.table img{
    width:50px;
    height:50px;
    object-fit:cover;
    border-radius:8px;
}

.chart-box{
    height:300px;
}

@media(max-width:991px){

    .sidebar{
        min-height:auto;
    }

    .sidebar a{
        margin-bottom:5px;
    }

}

</style>
</head>

<body>

<div class="container-fluid">

<div class="row">

    <!-- Sidebar -->

    <div class="col-lg-2 p-0">

        <div class="sidebar p-3">

            <div class="logo mb-4">
                Wanderlust
            </div>

            <a href="#" class="active">
                <i class="fa-solid fa-chart-line"></i>
                Dashboard
            </a>

            <a href="#">
                <i class="fa-solid fa-house"></i>
                Listings
            </a>

            <a href="/listings/new">
                <i class="fa-solid fa-plus"></i>
                Add Listing
            </a>

            <a href="#">
                <i class="fa-solid fa-comment"></i>
                Comments
            </a>

            <a href="#">
                <i class="fa-solid fa-calendar"></i>
                Bookings
            </a>

            <a href="#">
                <i class="fa-solid fa-users"></i>
                Users
            </a>

            <a href="#">
                <i class="fa-solid fa-chart-pie"></i>
                Analytics
            </a>

            <a href="#">
                <i class="fa-solid fa-gear"></i>
                Settings
            </a>

        </div>

    </div>

    <!-- Content -->

    <div class="col-lg-10">

        <!-- Navbar -->

        <nav class="navbar bg-white shadow-sm rounded mt-3 px-4 py-3">

            <div>
                <h5 class="mb-0">Welcome Back 👋</h5>
            </div>

            <div class="d-flex align-items-center gap-3">

                <i class="fa-regular fa-bell fs-5"></i>

                <img
                src="https://i.pravatar.cc/45"
                class="rounded-circle">

            </div>

        </nav>

        <!-- Stats -->

        <div class="row mt-4 g-4">

            <div class="col-md-6 col-xl-3">

                <div class="card stat-card shadow-sm">

                    <div class="card-body">

                        <div class="d-flex align-items-center gap-3">

                            <div class="icon-box bg-blue">
                                <i class="fa-solid fa-house"></i>
                            </div>

                            <div>
                                <h6>Total Listings</h6>
                                <h2>25</h2>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <div class="col-md-6 col-xl-3">

                <div class="card stat-card shadow-sm">

                    <div class="card-body">

                        <div class="d-flex align-items-center gap-3">

                            <div class="icon-box bg-green">
                                <i class="fa-regular fa-comment"></i>
                            </div>

                            <div>
                                <h6>Total Comments</h6>
                                <h2>128</h2>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <div class="col-md-6 col-xl-3">

                <div class="card stat-card shadow-sm">

                    <div class="card-body">

                        <div class="d-flex align-items-center gap-3">

                            <div class="icon-box bg-purple">
                                <i class="fa-regular fa-eye"></i>
                            </div>

                            <div>
                                <h6>Total Views</h6>
                                <h2>3450</h2>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <div class="col-md-6 col-xl-3">

                <div class="card stat-card shadow-sm">

                    <div class="card-body">

                        <div class="d-flex align-items-center gap-3">

                            <div class="icon-box bg-orange">
                                <i class="fa-regular fa-calendar"></i>
                            </div>

                            <div>
                                <h6>Total Bookings</h6>
                                <h2>86</h2>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Charts Placeholder -->

        <div class="row mt-4">

            <div class="col-lg-6 mb-4">

                <div class="card shadow-sm h-100">

                    <div class="card-body">

                        <h5>Listings By City</h5>

                        <div class="chart-box d-flex justify-content-center align-items-center">
                            <h2 class="text-muted">
                                Pie Chart Here
                            </h2>
                        </div>

                    </div>

                </div>

            </div>

            <div class="col-lg-6 mb-4">

                <div class="card shadow-sm h-100">

                    <div class="card-body">

                        <h5>Comments Over Time</h5>

                        <div class="chart-box d-flex justify-content-center align-items-center">

                            <h2 class="text-muted">
                                Line Chart Here
                            </h2>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Tables -->

        <div class="row">

            <div class="col-lg-6 mb-4">

                <div class="card shadow-sm">

                    <div class="card-body">

                        <h5>Recent Comments</h5>

                        <div class="table-responsive">

                            <table class="table">

                                <thead>

                                <tr>
                                    <th>User</th>
                                    <th>Comment</th>
                                    <th>Date</th>
                                </tr>

                                </thead>

                                <tbody>

                                <tr>
                                    <td>Rahul</td>
                                    <td>Great Stay!</td>
                                    <td>2h ago</td>
                                </tr>

                                <tr>
                                    <td>Priya</td>
                                    <td>Beautiful Villa</td>
                                    <td>5h ago</td>
                                </tr>

                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

            </div>

            <div class="col-lg-6 mb-4">

                <div class="card shadow-sm">

                    <div class="card-body">

                        <h5>Top Listings</h5>

                        <div class="table-responsive">

                            <table class="table">

                                <thead>

                                <tr>
                                    <th>Listing</th>
                                    <th>Views</th>
                                    <th>Bookings</th>
                                </tr>

                                </thead>

                                <tbody>

                                <tr>
                                    <td>Goa Villa</td>
                                    <td>250</td>
                                    <td>18</td>
                                </tr>

                                <tr>
                                    <td>Manali Cottage</td>
                                    <td>180</td>
                                    <td>12</td>
                                </tr>

                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>